{
  "_comment": "Hand-curated source list of schema.org types. Each type lists ONLY its own properties; build-registry.mjs walks the parent chain and pre-flattens 'allProperties' at build time. Filename retained from cycle 1 for continuity; cycle 5 (auto-sync) will replace this file with output from sync-schema.mjs (auto-fetch from schemaorg-current-https.jsonld).",
  "schemaVersion": "latest-2026-05",
  "types": {
    "Thing": {
      "parent": null,
      "properties": {
        "name": ["Text"],
        "description": ["Text"],
        "url": ["URL"],
        "image": ["URL", "ImageObject"],
        "identifier": ["Text", "URL", "PropertyValue"]
      }
    },
    "CreativeWork": {
      "parent": "Thing",
      "properties": {
        "author": ["Person", "Organization"],
        "datePublished": ["Date"],
        "dateModified": ["Date"],
        "headline": ["Text"],
        "publisher": ["Organization", "Person"],
        "about": ["Text", "Thing"],
        "inLanguage": ["Text"]
      }
    },
    "Article": {
      "parent": "CreativeWork",
      "properties": {
        "articleBody": ["Text"],
        "articleSection": ["Text"],
        "wordCount": ["Integer"]
      }
    },
    "NewsArticle": {
      "parent": "Article",
      "properties": {
        "dateline": ["Text"],
        "printSection": ["Text"]
      }
    },
    "BlogPosting": {
      "parent": "Article",
      "properties": {}
    },
    "Person": {
      "parent": "Thing",
      "properties": {
        "givenName": ["Text"],
        "familyName": ["Text"],
        "jobTitle": ["Text"],
        "email": ["Text"],
        "telephone": ["Text"],
        "worksFor": ["Organization"],
        "affiliation": ["Organization"]
      }
    },
    "Organization": {
      "parent": "Thing",
      "properties": {
        "legalName": ["Text"],
        "founder": ["Person"],
        "foundingDate": ["Date"],
        "email": ["Text"],
        "telephone": ["Text"],
        "numberOfEmployees": ["Integer"]
      }
    },
    "Product": {
      "parent": "Thing",
      "properties": {
        "brand": ["Brand", "Organization"],
        "sku": ["Text"],
        "model": ["Text", "ProductModel"],
        "gtin": ["Text"],
        "manufacturer": ["Organization"],
        "offers": ["Offer", "Demand"],
        "review": ["Review"],
        "aggregateRating": ["AggregateRating"],
        "mpn": ["Text"],
        "audience": ["Audience"]
      }
    }
  }
}
